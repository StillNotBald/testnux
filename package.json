{
  "name": "testnux",
  "version": "0.0.1",
  "description": "Generate auditor-ready test artifacts from markdown test plans and Playwright evidence.",
  "private": false,
  "license": "Apache-2.0",
  "author": "Chu Ling",
  "repository": {
    "type": "git",
    "url": "https://github.com/StillNotBald/testnux.git"
  },
  "homepage": "https://github.com/StillNotBald/testnux#readme",
  "bugs": {
    "url": "https://github.com/StillNotBald/testnux/issues"
  },
  "keywords": [
    "testing",
    "audit",
    "compliance",
    "playwright",
    "soc2",
    "nist",
    "owasp",
    "wcag",
    "test-report",
    "evidence",
    "traceability"
  ],
  "type": "module",
  "bin": {
    "testnux": "bin/testnux.mjs"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/",
    "docs/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/ bin/ test/",
    "lint:fix": "eslint src/ bin/ test/ --fix",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "sharp": "^0.33.4"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
