<script>
(function () {
  'use strict';

  // ── Tab filtering ────────────────────────────────────────────────
  var tabs = document.querySelectorAll('.tab-btn');
  var cards = document.querySelectorAll('.tc-card');

  function setActiveTab(btn) {
    tabs.forEach(function (t) { t.classList.remove('active'); });
    btn.classList.add('active');
  }

  function filterCards(status) {
    cards.forEach(function (card) {
      if (status === 'all') {
        card.style.display = '';
      } else {
        card.style.display = (card.dataset.status === status) ? '' : 'none';
      }
    });
  }

  tabs.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setActiveTab(btn);
      filterCards(btn.dataset.filter);
    });
  });

  // ── TOC active highlight on scroll ──────────────────────────────
  var tocLinks = document.querySelectorAll('#toc-nav a');

  function highlightTOC() {
    var scrollY = window.scrollY || window.pageYOffset;
    var closest = null;
    var closestDist = Infinity;

    tocLinks.forEach(function (link) {
      var href = link.getAttribute('href');
      var target = document.querySelector(href);
      if (!target) return;
      var dist = Math.abs(target.getBoundingClientRect().top);
      if (dist < closestDist) {
        closestDist = dist;
        closest = link;
      }
    });

    tocLinks.forEach(function (l) { l.classList.remove('active'); });
    if (closest && closestDist < 200) {
      closest.classList.add('active');
    }
  }

  window.addEventListener('scroll', highlightTOC, { passive: true });
  highlightTOC();

  // ── Image fallback (belt-and-suspenders) ────────────────────────
  document.querySelectorAll('.evidence-img-wrap img').forEach(function (img) {
    img.addEventListener('error', function () {
      img.style.display = 'none';
      var placeholder = img.nextElementSibling;
      if (placeholder) placeholder.style.display = 'flex';
    });
  });

})();
</script>

</body>
